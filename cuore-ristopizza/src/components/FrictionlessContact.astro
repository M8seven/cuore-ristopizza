---
import { Phone, MessageCircle } from '@lucide/astro';
import { BUSINESS } from '../data/business';
---

<aside
  id="frictionless-contact"
  class="fixed inset-x-0 bottom-0 z-50 pointer-events-none md:inset-x-auto md:right-6 md:bottom-6 md:top-auto md:left-auto opacity-0 translate-y-4 transition-all duration-300"
  aria-label="Contatti rapidi"
  data-frictionless
>
  <!-- Mobile: full-width bottom bar split 50/50 -->
  <div class="flex md:hidden safe-bottom shadow-[0_-6px_24px_rgba(0,0,0,0.08)]">
    <a
      href={BUSINESS.whatsappHref}
      target="_blank"
      rel="noopener"
      aria-label="Contattaci su WhatsApp"
      class="pointer-events-auto flex-1 flex items-center justify-center gap-2 py-4 bg-[var(--color-whatsapp)] text-white font-semibold text-base active:bg-[var(--color-whatsapp-dark)]"
    >
      <MessageCircle size={22} stroke-width={2.25} aria-hidden="true" />
      WhatsApp
    </a>
    <a
      href={BUSINESS.phoneHref}
      aria-label={`Chiama ${BUSINESS.name}`}
      class="pointer-events-auto flex-1 flex items-center justify-center gap-2 py-4 bg-[var(--color-accent)] text-white font-semibold text-base active:bg-[var(--color-accent-dark)]"
    >
      <Phone size={22} stroke-width={2.25} aria-hidden="true" />
      Chiama
    </a>
  </div>

  <!-- Desktop: stacked circular FABs -->
  <div class="hidden md:flex flex-col gap-3 items-end">
    <a
      href={BUSINESS.whatsappHref}
      target="_blank"
      rel="noopener"
      aria-label="Contattaci su WhatsApp"
      class="pointer-events-auto group flex items-center gap-3 h-14 pl-5 pr-6 rounded-full bg-[var(--color-whatsapp)] text-white shadow-xl shadow-black/15 hover:bg-[var(--color-whatsapp-dark)] hover:scale-[1.03] transition-transform focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--color-whatsapp)]"
    >
      <MessageCircle size={22} stroke-width={2.25} aria-hidden="true" />
      <span class="font-semibold text-sm">WhatsApp</span>
    </a>
    <a
      href={BUSINESS.phoneHref}
      aria-label={`Chiama ${BUSINESS.name}`}
      class="pointer-events-auto group flex items-center gap-3 h-14 pl-5 pr-6 rounded-full bg-[var(--color-accent)] text-white shadow-xl shadow-black/15 hover:bg-[var(--color-accent-dark)] hover:scale-[1.03] transition-transform focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--color-accent)]"
    >
      <Phone size={22} stroke-width={2.25} aria-hidden="true" />
      <span class="font-semibold text-sm">Chiamaci</span>
    </a>
  </div>
</aside>

<script>
  // Reveal the floating contact after user scrolls past the hero
  const el = document.getElementById('frictionless-contact');
  if (el) {
    const reveal = () => {
      el.classList.remove('opacity-0', 'translate-y-4');
      el.classList.add('opacity-100', 'translate-y-0');
    };
    const hide = () => {
      el.classList.remove('opacity-100', 'translate-y-0');
      el.classList.add('opacity-0', 'translate-y-4');
    };

    // Show after scrolling 80vh (past hero)
    const threshold = () => window.innerHeight * 0.8;
    const onScroll = () => {
      if (window.scrollY > threshold()) reveal();
      else hide();
    };
    onScroll();
    window.addEventListener('scroll', onScroll, { passive: true });
  }
</script>
