---
import { Calendar, Beef, Fish, ArrowRight } from '@lucide/astro';
import { BUSINESS } from '../data/business';
import SectionNumber from './SectionNumber.astro';

const events = [
  {
    day: 'Mercoledì',
    icon: Beef,
    title: 'Hamburger Day',
    body:
      'Panini artigianali dal cuore pugliese: WCS, Hazzard e il nostro Italiano con capocollo di Martina Franca.',
    cta: { label: 'Prenota via WhatsApp', href: BUSINESS.whatsappHref, external: true },
    accent: 'from-amber-50 to-amber-100/40 text-amber-900 border-amber-200',
    iconBg: 'bg-amber-200/50 text-amber-800',
  },
  {
    day: 'Giovedì',
    icon: Fish,
    title: 'Frittura di mare e calamari',
    body:
      'Una serata dedicata al mare: frittura croccante di pesce e calamari. Disponibile solo su prenotazione.',
    cta: { label: 'Chiama per prenotare', href: BUSINESS.phoneHref, external: false },
    accent: 'from-sky-50 to-sky-100/40 text-sky-900 border-sky-200',
    iconBg: 'bg-sky-200/50 text-sky-800',
  },
];
---

<section
  id="eventi"
  class="relative py-16 md:py-24 scroll-mt-20"
  aria-labelledby="events-title"
>
  <div class="max-w-6xl mx-auto px-5 md:px-8">
    <div class="reveal flex flex-col md:flex-row md:items-end justify-between gap-4">
      <div class="max-w-2xl">
        <SectionNumber num="04" label="Eventi settimanali" />
        <h2
          id="events-title"
          class="font-[family-name:var(--font-display)] font-bold text-3xl md:text-5xl lg:text-6xl"
        >
          Appuntamenti<br />
          <span class="italic font-normal text-[var(--color-accent)]">che non puoi perdere.</span>
        </h2>
      </div>
      <p class="text-[var(--color-ink-soft)] max-w-md">
        Ogni settimana portiamo in tavola qualcosa di diverso. Prenota il tavolo per essere sicuro
        del tuo posto.
      </p>
    </div>

    <div class="mt-12 grid gap-6 md:grid-cols-2" data-reveal-stagger>
      {events.map((e) => (
        <article
          class={`reveal card-lift relative overflow-hidden p-8 md:p-10 rounded-[var(--radius-card-lg)] border bg-gradient-to-br ${e.accent}`}
        >
          <Calendar
            size={140}
            aria-hidden="true"
            class="absolute -top-6 -right-6 opacity-[0.06]"
          />
          <div class="relative flex items-center gap-4">
            <span class={`inline-flex items-center justify-center w-12 h-12 rounded-full ${e.iconBg}`}>
              <e.icon size={22} aria-hidden="true" />
            </span>
            <div>
              <p class="text-xs font-semibold uppercase tracking-[0.2em] opacity-75">{e.day}</p>
              <h3 class="text-2xl font-bold">{e.title}</h3>
            </div>
          </div>
          <p class="relative mt-5 leading-relaxed">{e.body}</p>
          <a
            href={e.cta.href}
            target={e.cta.external ? '_blank' : undefined}
            rel={e.cta.external ? 'noopener' : undefined}
            class="group relative mt-6 inline-flex items-center gap-2 h-11 px-5 rounded-full bg-[var(--color-ink)] text-white font-semibold hover:bg-black transition-all hover:gap-3"
          >
            {e.cta.label}
            <ArrowRight size={16} aria-hidden="true" class="transition-transform group-hover:translate-x-0.5" />
          </a>
        </article>
      ))}
    </div>
  </div>
</section>
