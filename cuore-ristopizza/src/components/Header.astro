---
import { Menu as MenuIcon, X } from '@lucide/astro';
import { BUSINESS } from '../data/business';

const base = import.meta.env.BASE_URL;

const nav = [
  { href: `${base}#menu`, label: 'Menu' },
  { href: `${base}#eventi`, label: 'Eventi' },
  { href: `${base}contatti`, label: 'Contatti' },
];
---

<header
  class="sticky top-0 z-40 backdrop-blur-md bg-[color-mix(in_srgb,var(--color-cream)_82%,transparent)] border-b border-black/5"
>
  <div class="max-w-6xl mx-auto px-5 md:px-8 h-16 md:h-20 flex items-center justify-between gap-4">
    <a href={base} class="flex items-baseline gap-2 font-[family-name:var(--font-display)]" aria-label={`${BUSINESS.name} — Home`}>
      <span class="text-[1.35rem] md:text-2xl font-bold tracking-tight">Cuore</span>
      <span class="text-sm md:text-base text-[var(--color-ink-soft)] tracking-wider uppercase">Ristopizza</span>
    </a>

    <nav class="hidden md:flex items-center gap-8 text-sm font-medium" aria-label="Principale">
      {nav.map((n) => (
        <a
          href={n.href}
          class="text-[var(--color-ink)] hover:text-[var(--color-accent)] transition-colors"
        >
          {n.label}
        </a>
      ))}
      <a
        href={BUSINESS.whatsappHref}
        target="_blank"
        rel="noopener"
        class="inline-flex items-center h-10 px-5 rounded-full bg-[var(--color-accent)] text-white font-semibold hover:bg-[var(--color-accent-dark)] transition-colors"
      >
        Ordina
      </a>
    </nav>

    <button
      type="button"
      id="mobile-menu-toggle"
      aria-label="Apri menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
      class="md:hidden p-2 -mr-2 rounded-md text-[var(--color-ink)] hover:bg-black/5"
    >
      <MenuIcon size={24} aria-hidden="true" />
    </button>
  </div>
</header>

<!-- Mobile sheet -->
<div
  id="mobile-menu"
  class="fixed inset-0 z-50 hidden bg-[var(--color-cream)] flex-col"
  aria-hidden="true"
>
  <div class="flex items-center justify-between h-16 px-5 border-b border-black/5">
    <span class="font-[family-name:var(--font-display)] text-xl font-bold">Cuore Ristopizza</span>
    <button
      type="button"
      id="mobile-menu-close"
      aria-label="Chiudi menu"
      class="p-2 -mr-2 rounded-md hover:bg-black/5"
    >
      <X size={24} aria-hidden="true" />
    </button>
  </div>
  <nav class="flex flex-col p-6 gap-1 text-xl font-medium" aria-label="Menu mobile">
    {nav.map((n) => (
      <a
        href={n.href}
        class="py-3 border-b border-black/5 hover:text-[var(--color-accent)]"
        data-close-menu
      >
        {n.label}
      </a>
    ))}
    <a
      href={BUSINESS.whatsappHref}
      target="_blank"
      rel="noopener"
      class="mt-6 inline-flex items-center justify-center h-12 px-6 rounded-full bg-[var(--color-accent)] text-white font-semibold"
      data-close-menu
    >
      Ordina su WhatsApp
    </a>
  </nav>
</div>

<script>
  const toggle = document.getElementById('mobile-menu-toggle');
  const close = document.getElementById('mobile-menu-close');
  const sheet = document.getElementById('mobile-menu');

  function open() {
    if (!sheet || !toggle) return;
    sheet.classList.remove('hidden');
    sheet.classList.add('flex');
    sheet.setAttribute('aria-hidden', 'false');
    toggle.setAttribute('aria-expanded', 'true');
    document.body.style.overflow = 'hidden';
  }
  function hide() {
    if (!sheet || !toggle) return;
    sheet.classList.add('hidden');
    sheet.classList.remove('flex');
    sheet.setAttribute('aria-hidden', 'true');
    toggle.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
  }

  toggle?.addEventListener('click', open);
  close?.addEventListener('click', hide);
  document.querySelectorAll('[data-close-menu]').forEach((a) => a.addEventListener('click', hide));
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') hide();
  });
</script>
