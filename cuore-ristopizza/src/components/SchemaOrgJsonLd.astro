---
import { BUSINESS } from '../data/business';

// Map short day names to Schema.org dayOfWeek values
const DAY_MAP: Record<string, string> = {
  'Lunedì': 'Monday',
  'Martedì': 'Tuesday',
  'Mercoledì': 'Wednesday',
  'Giovedì': 'Thursday',
  'Venerdì': 'Friday',
  'Sabato': 'Saturday',
  'Domenica': 'Sunday',
};

const openingHoursSpecification = BUSINESS.hours
  .filter((h) => !h.closed)
  .flatMap((h) =>
    h.slots.map((slot) => {
      const [opens, closes] = slot.split('-');
      return {
        '@type': 'OpeningHoursSpecification',
        dayOfWeek: DAY_MAP[h.day],
        opens,
        closes,
      };
    })
  );

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': ['Restaurant', 'LocalBusiness'],
  '@id': `${Astro.site?.toString() ?? 'https://cuoreristopizza.it/'}#restaurant`,
  name: BUSINESS.name,
  description: BUSINESS.description,
  url: Astro.site?.toString() ?? 'https://cuoreristopizza.it/',
  telephone: BUSINESS.phoneRaw,
  email: BUSINESS.email,
  priceRange: '€€',
  servesCuisine: ['Pizza', 'Italian', 'Pugliese', 'Calabrese'],
  address: {
    '@type': 'PostalAddress',
    streetAddress: BUSINESS.address.street,
    addressLocality: BUSINESS.address.city,
    postalCode: BUSINESS.address.postal,
    addressRegion: BUSINESS.address.region,
    addressCountry: BUSINESS.address.country,
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: BUSINESS.geo.lat,
    longitude: BUSINESS.geo.lng,
  },
  openingHoursSpecification,
  sameAs: [BUSINESS.social.facebook, BUSINESS.social.instagram],
  image: new URL('/og-image.jpg', Astro.site ?? 'https://cuoreristopizza.it/').toString(),
  acceptsReservations: 'True',
};
---

<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} is:inline />
