---
import { MapPin, Phone, Mail, Clock } from '@lucide/astro';
import { BUSINESS } from '../data/business';
import PaymentBadges from './PaymentBadges.astro';

// Group hours into compact lines
const groupedHours = [
  { label: 'Martedì — Sabato', slots: ['11:30 — 14:30', '18:30 — 22:00'] },
  { label: 'Domenica', slots: ['18:30 — 22:00'] },
  { label: 'Lunedì', slots: ['Chiuso'], closed: true },
];

const year = new Date().getFullYear();
const mapsQuery = encodeURIComponent(
  `${BUSINESS.address.street}, ${BUSINESS.address.postal} ${BUSINESS.address.city} ${BUSINESS.address.region}`
);
---

<footer class="mt-24 pt-16 pb-28 md:pb-16 border-t border-black/5 bg-white/50">
  <div class="max-w-6xl mx-auto px-5 md:px-8 grid gap-12 md:grid-cols-4">
    <div class="md:col-span-1">
      <p class="font-[family-name:var(--font-display)] text-2xl font-bold">Cuore</p>
      <p class="text-[var(--color-ink-soft)] text-sm uppercase tracking-wider">Ristopizza</p>
      <p class="mt-4 text-sm text-[var(--color-ink-soft)] leading-relaxed">
        Pizzeria artigianale a Cogliate. Impasti ad alta digeribilità, accoglienza family-friendly
        e pet-friendly.
      </p>
      <div class="mt-5 flex items-center gap-3">
        <a
          href={BUSINESS.social.facebook}
          target="_blank"
          rel="noopener"
          aria-label="Facebook"
          class="inline-flex items-center justify-center w-10 h-10 rounded-full border border-black/10 hover:bg-[var(--color-accent)] hover:text-white hover:border-transparent transition-colors"
        >
          <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true">
            <path d="M9 8h-3v4h3v12h5v-12h3.642l.358-4h-4v-1.667c0-.955.192-1.333 1.115-1.333h2.885v-5h-3.808c-3.596 0-5.192 1.583-5.192 4.615v3.385z" />
          </svg>
        </a>
        <a
          href={BUSINESS.social.instagram}
          target="_blank"
          rel="noopener"
          aria-label="Instagram"
          class="inline-flex items-center justify-center w-10 h-10 rounded-full border border-black/10 hover:bg-[var(--color-accent)] hover:text-white hover:border-transparent transition-colors"
        >
          <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true">
            <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z" />
          </svg>
        </a>
      </div>
    </div>

    <div>
      <h3 class="text-sm font-semibold uppercase tracking-wider text-[var(--color-ink-soft)]">
        <Clock size={14} class="inline align-[-2px] mr-1" aria-hidden="true" /> Orari
      </h3>
      <ul class="mt-4 space-y-3 text-sm">
        {groupedHours.map((g) => (
          <li>
            <p class="font-medium">{g.label}</p>
            <p class={g.closed ? 'text-[var(--color-accent)] font-medium' : 'text-[var(--color-ink-soft)]'}>
              {g.slots.join(' · ')}
            </p>
          </li>
        ))}
      </ul>
    </div>

    <div>
      <h3 class="text-sm font-semibold uppercase tracking-wider text-[var(--color-ink-soft)]">Dove siamo</h3>
      <ul class="mt-4 space-y-3 text-sm">
        <li class="flex gap-2">
          <MapPin size={16} class="shrink-0 mt-0.5" aria-hidden="true" />
          <a
            href={`https://maps.google.com/?q=${mapsQuery}`}
            target="_blank"
            rel="noopener"
            class="hover:text-[var(--color-accent)]"
          >
            {BUSINESS.address.street}<br />
            {BUSINESS.address.postal} {BUSINESS.address.city} ({BUSINESS.address.region})
          </a>
        </li>
        <li class="flex gap-2">
          <Phone size={16} class="shrink-0 mt-0.5" aria-hidden="true" />
          <a href={BUSINESS.phoneHref} class="hover:text-[var(--color-accent)]">{BUSINESS.phone}</a>
        </li>
        <li class="flex gap-2">
          <Mail size={16} class="shrink-0 mt-0.5" aria-hidden="true" />
          <a href={`mailto:${BUSINESS.email}`} class="hover:text-[var(--color-accent)] break-all">
            {BUSINESS.email}
          </a>
        </li>
      </ul>
    </div>

    <div>
      <h3 class="text-sm font-semibold uppercase tracking-wider text-[var(--color-ink-soft)]">Pagamenti</h3>
      <div class="mt-4">
        <PaymentBadges />
      </div>
    </div>
  </div>

  <div class="max-w-6xl mx-auto mt-12 px-5 md:px-8 pt-6 border-t border-black/5 flex flex-col md:flex-row items-start md:items-center justify-between gap-3 text-xs text-[var(--color-ink-soft)]">
    <p>© {year} {BUSINESS.name}. Tutti i diritti riservati.</p>
    <nav class="flex items-center gap-5" aria-label="Legale">
      <a href="/privacy-policy" class="hover:text-[var(--color-accent)]">Privacy</a>
      <a href="/cookie-policy" class="hover:text-[var(--color-accent)]">Cookie</a>
    </nav>
  </div>
</footer>
