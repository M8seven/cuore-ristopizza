---
import BaseLayout from '../layouts/BaseLayout.astro';
import IngredientSprite from '../components/IngredientSprite.astro';

type Shape = 'tomato' | 'basil' | 'mozza' | 'olive' | 'chili' | 'mushroom' | 'salami' | 'garlic' | 'rucola';

interface PizzaProto {
  id: string;
  name: string;
  price: number;
  desc: string;
  ingredients: { shape: Shape; angle: number; label: string }[];
  badge?: 'heart' | 'spicy';
}

const pizzas: PizzaProto[] = [
  {
    id: 'margherita',
    name: 'Margherita',
    price: 5.0,
    desc: 'Pomodoro, fiordilatte.',
    ingredients: [
      { shape: 'tomato', angle: -50, label: 'Pomodoro' },
      { shape: 'mozza',  angle: 30,  label: 'Fiordilatte' },
      { shape: 'basil',  angle: 130, label: 'Basilico' },
      { shape: 'olive',  angle: 210, label: 'Olio EVO' },
    ],
  },
  {
    id: 'diavola',
    name: 'Diavola',
    price: 7.0,
    desc: 'Pomodoro, fiordilatte, spianata calabrese.',
    badge: 'spicy',
    ingredients: [
      { shape: 'tomato', angle: -50, label: 'Pomodoro' },
      { shape: 'mozza',  angle: 30,  label: 'Fiordilatte' },
      { shape: 'salami', angle: 130, label: 'Calabrese' },
      { shape: 'chili',  angle: 210, label: 'Pepperoncino' },
    ],
  },
  {
    id: 'cuore',
    name: 'Cuore',
    price: 8.0,
    desc: "Pomodoro, stracciatella, prosciutto crudo d'Oggiono, rucola.",
    badge: 'heart',
    ingredients: [
      { shape: 'tomato', angle: -50, label: 'Pomodoro' },
      { shape: 'mozza',  angle: 30,  label: 'Stracciatella' },
      { shape: 'salami', angle: 130, label: 'Crudo' },
      { shape: 'rucola', angle: 210, label: 'Rucola' },
    ],
  },
];

const priceFmt = (n: number) =>
  new Intl.NumberFormat('it-IT', { style: 'currency', currency: 'EUR' }).format(n);
---

<BaseLayout title="Prototipo 2 — Ingredienti che esplodono" noindex={true}>
  <IngredientSprite />

  <section class="relative min-h-[100vh] py-20 md:py-28 bg-gradient-to-b from-[var(--color-cream)] to-[var(--color-cream-warm)]">
    <div class="max-w-6xl mx-auto px-5 md:px-8">
      <header class="reveal text-center max-w-2xl mx-auto mb-16">
        <p class="text-xs sm:text-sm font-semibold tracking-[0.3em] uppercase text-[var(--color-accent)]">Prototipo 2 · v2</p>
        <h1 class="mt-4 font-[family-name:var(--font-display)] font-bold text-4xl md:text-6xl">
          Ingredienti<br />
          <span class="italic font-normal text-[var(--color-accent)]">che esplodono.</span>
        </h1>
        <p class="mt-5 text-[var(--color-ink-soft)] text-lg leading-relaxed">
          Passa il mouse (o tocca) sopra una pizza. Gli ingredienti si dispongono attorno alla forma.
          <span class="block text-sm mt-2 italic opacity-75">Su mobile, tocca la card per attivare l'effetto.</span>
        </p>
      </header>

      <div class="grid gap-8 md:grid-cols-3" data-reveal-stagger>
        {pizzas.map((pizza) => (
          <article
            class="reveal pizza-card group relative bg-white rounded-[var(--radius-card-lg)] border border-black/5 shadow-md shadow-black/5 p-6 cursor-pointer overflow-visible transition-[transform,box-shadow] duration-500 hover:-translate-y-2 hover:shadow-2xl hover:shadow-black/15"
            tabindex="0"
          >
            <!-- Plate / pizza visual -->
            <div class="plate-wrap relative mx-auto aspect-square w-44 mb-5">
              <svg viewBox="0 0 300 300" class="absolute inset-0 w-full h-full" aria-hidden="true">
                <use href="#ing-pizza-plate" />
              </svg>

              <!-- Ingredients (realistic SVG) that fly out on hover -->
              {pizza.ingredients.map((ing) => (
                <span
                  class="ingredient absolute top-1/2 left-1/2 select-none pointer-events-none w-12 h-12 -ml-6 -mt-6"
                  style={`--angle: ${ing.angle}deg;`}
                  aria-label={ing.label}
                >
                  <svg viewBox="0 0 100 100" class="w-full h-full" aria-hidden="true">
                    <use href={`#ing-${ing.shape}`} />
                  </svg>
                </span>
              ))}

              <!-- Badge -->
              {pizza.badge === 'heart' && (
                <span class="absolute -top-2 -right-2 inline-flex items-center justify-center w-10 h-10 rounded-full bg-[var(--color-accent)] text-white text-xl shadow-lg z-10">❤</span>
              )}
              {pizza.badge === 'spicy' && (
                <span class="absolute -top-2 -right-2 inline-flex items-center justify-center w-10 h-10 rounded-full bg-red-100 text-red-700 text-lg shadow-lg z-10">🌶</span>
              )}
            </div>

            <h2 class="font-[family-name:var(--font-display)] text-3xl font-bold text-center">
              {pizza.name}
            </h2>
            <p class="mt-2 text-sm text-[var(--color-ink-soft)] text-center leading-relaxed min-h-[3rem]">
              {pizza.desc}
            </p>
            <div class="mt-4 flex items-center justify-center">
              <data
                value={pizza.price}
                class="font-[family-name:var(--font-display)] text-3xl font-bold text-[var(--color-accent)]"
              >
                {priceFmt(pizza.price)}
              </data>
            </div>

            <p class="hint mt-3 text-center text-xs text-[var(--color-ink-soft)] italic opacity-70 transition-opacity group-hover:opacity-0">
              Passa sopra ↑
            </p>
          </article>
        ))}
      </div>

      <div class="mt-16 flex flex-col sm:flex-row items-center justify-center gap-3">
        <a href="prototipo-1" class="inline-flex items-center gap-2 h-12 px-6 rounded-full bg-[var(--color-ink)] text-white font-semibold hover:bg-black transition-colors">
          ← Vedi Prototipo 1
        </a>
        <a href={import.meta.env.BASE_URL} class="inline-flex items-center gap-2 h-12 px-6 rounded-full bg-white border border-black/10 text-[var(--color-ink)] font-semibold hover:bg-black/5 transition-colors">
          Torna al sito
        </a>
      </div>
    </div>
  </section>

  <style>
    .ingredient {
      transform: translate(0, 0) rotate(var(--angle, 0deg)) translateX(0) rotate(calc(var(--angle, 0deg) * -1)) scale(0);
      opacity: 0;
      transition:
        transform 0.6s cubic-bezier(0.34, 1.56, 0.64, 1),
        opacity 0.4s ease;
      filter: drop-shadow(0 6px 10px rgba(0, 0, 0, 0.25));
    }
    .pizza-card:hover .ingredient,
    .pizza-card:focus-within .ingredient,
    .pizza-card.is-active .ingredient {
      transform: translate(0, 0) rotate(var(--angle, 0deg)) translateX(108px) rotate(calc(var(--angle, 0deg) * -1)) scale(1);
      opacity: 1;
    }
    /* SVG is at position 1, so ingredients start at position 2 (no extra delay) */
    .pizza-card:hover .ingredient:nth-child(3),
    .pizza-card:focus-within .ingredient:nth-child(3),
    .pizza-card.is-active .ingredient:nth-child(3) { transition-delay: 0.06s; }
    .pizza-card:hover .ingredient:nth-child(4),
    .pizza-card:focus-within .ingredient:nth-child(4),
    .pizza-card.is-active .ingredient:nth-child(4) { transition-delay: 0.12s; }
    .pizza-card:hover .ingredient:nth-child(5),
    .pizza-card:focus-within .ingredient:nth-child(5),
    .pizza-card.is-active .ingredient:nth-child(5) { transition-delay: 0.18s; }

    /* Subtle continuous wobble on the pizza plate while card is hovered */
    @keyframes plate-wobble {
      0%, 100% { transform: rotate(0deg); }
      50%      { transform: rotate(2deg); }
    }
    .pizza-card:hover .plate-wrap > svg:first-child {
      animation: plate-wobble 4s ease-in-out infinite;
    }

    @media (prefers-reduced-motion: reduce) {
      .ingredient {
        transition: opacity 0.2s ease;
        transform: rotate(var(--angle, 0deg)) translateX(108px) rotate(calc(var(--angle, 0deg) * -1)) scale(1);
        opacity: 1;
      }
    }
  </style>

  <script>
    document.querySelectorAll<HTMLElement>('.pizza-card').forEach((card) => {
      card.addEventListener('click', (e) => {
        if ((e.target as HTMLElement).closest('a')) return;
        if (!window.matchMedia('(hover: hover)').matches) {
          card.classList.toggle('is-active');
        }
      });
    });
  </script>
</BaseLayout>
