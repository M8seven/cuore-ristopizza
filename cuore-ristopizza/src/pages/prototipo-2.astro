---
import BaseLayout from '../layouts/BaseLayout.astro';

interface PizzaCard {
  id: string;
  name: string;
  price: number;
  desc: string;
  ingredients: string[];
  photo: string;
  badge?: 'heart' | 'spicy';
}

const base = import.meta.env.BASE_URL;

const pizzas: PizzaCard[] = [
  {
    id: 'margherita',
    name: 'Margherita',
    price: 5.0,
    desc: "L'essenziale: pomodoro San Marzano e fiordilatte filante.",
    ingredients: ['Pomodoro', 'Fiordilatte', 'Basilico', 'Olio EVO'],
    photo: `${base}photos/margherita.jpg`,
  },
  {
    id: 'diavola',
    name: 'Diavola',
    price: 7.0,
    desc: 'Calabrese piccante e mozzarella, una versione del Sud che non si tira indietro.',
    ingredients: ['Pomodoro', 'Fiordilatte', 'Spianata Calabrese', "Pizzichio piccante"],
    photo: `${base}photos/diavola.jpg`,
    badge: 'spicy',
  },
  {
    id: 'cuore',
    name: 'Cuore',
    price: 8.0,
    desc: "Servita a forma di cuore. Stracciatella, crudo d'Oggiono, rucola.",
    ingredients: ['Pomodoro', 'Stracciatella', "Crudo d'Oggiono", 'Rucola'],
    photo: `${base}photos/margherita-2.jpg`,
    badge: 'heart',
  },
];

const priceFmt = (n: number) =>
  new Intl.NumberFormat('it-IT', { style: 'currency', currency: 'EUR' }).format(n);
---

<BaseLayout title="Prototipo 2 — Le nostre pizze" noindex={true}>
  <section class="relative min-h-[100vh] py-20 md:py-28 bg-[#0d0907] text-white overflow-hidden">
    <div
      class="absolute inset-0 opacity-30 pointer-events-none"
      style="background: radial-gradient(ellipse at 50% 20%, rgba(198,40,40,0.4), transparent 60%);"
      aria-hidden="true"
    ></div>

    <div class="relative max-w-6xl mx-auto px-5 md:px-8">
      <header class="reveal text-center max-w-2xl mx-auto mb-16">
        <p class="text-xs sm:text-sm font-semibold tracking-[0.3em] uppercase text-[#ff8a6a]">Prototipo 2 · v3.1</p>
        <h1 class="mt-4 font-[family-name:var(--font-display)] font-bold text-4xl md:text-6xl">
          Le nostre<br />
          <span class="italic font-normal text-[#ff8a6a]">pizze.</span>
        </h1>
        <p class="mt-5 text-white/70 text-lg leading-relaxed">
          Passa il mouse (o tocca) sopra una pizza. Il pannello si apre con gli ingredienti.
        </p>
      </header>

      <div class="grid gap-7 md:grid-cols-3" data-reveal-stagger>
        {pizzas.map((pizza) => (
          <article
            class="reveal pizza-card group relative rounded-[var(--radius-card-lg)] overflow-hidden cursor-pointer shadow-xl shadow-black/40"
            tabindex="0"
            data-card
          >
            <!-- Photo frame -->
            <div class="relative aspect-[3/4] overflow-hidden">
              <img
                src={pizza.photo}
                alt={`Pizza ${pizza.name}`}
                class="photo absolute inset-0 w-full h-full object-cover transition-transform duration-[1400ms] ease-[cubic-bezier(0.22,1,0.36,1)] group-hover:scale-110"
                loading="lazy"
                decoding="async"
              />

              <!-- Top badge -->
              {pizza.badge === 'heart' && (
                <span class="absolute top-4 right-4 inline-flex items-center justify-center w-10 h-10 rounded-full bg-[var(--color-accent)] text-white text-lg shadow-lg z-20">❤</span>
              )}
              {pizza.badge === 'spicy' && (
                <span class="absolute top-4 right-4 inline-flex items-center justify-center w-10 h-10 rounded-full bg-red-500/90 text-white text-lg shadow-lg z-20">🌶</span>
              )}

              <!-- Photo dimming on hover (so chips read better) -->
              <div
                class="absolute inset-0 bg-black/0 transition-colors duration-500 group-hover:bg-black/30 group-focus-within:bg-black/30 group-[.is-active]:bg-black/30"
                aria-hidden="true"
              ></div>
            </div>

            <!-- Info panel — expands from bottom on hover, no overlap with title -->
            <div class="info-panel absolute inset-x-0 bottom-0 z-10">
              <!-- Always-visible header (name + price) -->
              <div
                class="info-header relative px-6 pb-5 pt-12 transition-[padding] duration-500"
                style="background: linear-gradient(to top, rgba(13,9,7,0.95) 0%, rgba(13,9,7,0.7) 60%, transparent 100%);"
              >
                <div class="flex items-end justify-between gap-3">
                  <h2 class="font-[family-name:var(--font-display)] text-3xl md:text-4xl font-bold leading-tight drop-shadow-lg">
                    {pizza.name}
                  </h2>
                  <data
                    value={pizza.price}
                    class="font-[family-name:var(--font-display)] text-2xl font-bold text-[#ff8a6a] shrink-0"
                  >
                    {priceFmt(pizza.price)}
                  </data>
                </div>
                <p class="mt-1 text-xs text-white/50 italic transition-opacity duration-300 group-hover:opacity-0 group-focus-within:opacity-0 group-[.is-active]:opacity-0">
                  Passa sopra ↑
                </p>
              </div>

              <!-- Ingredients drawer (slides up on hover) -->
              <div
                class="ingredients-drawer overflow-hidden max-h-0 transition-[max-height] duration-500 ease-[cubic-bezier(0.22,1,0.36,1)] group-hover:max-h-[280px] group-focus-within:max-h-[280px] group-[.is-active]:max-h-[280px]"
                style="background: rgba(13,9,7,0.95);"
              >
                <div class="px-6 pt-2 pb-6">
                  <p class="text-[11px] font-semibold tracking-[0.25em] uppercase text-[#ff8a6a]/80 mb-2">Ingredienti</p>
                  <p class="text-sm text-white/75 leading-relaxed mb-4 line-clamp-3">{pizza.desc}</p>
                  <ul class="flex flex-wrap gap-1.5">
                    {pizza.ingredients.map((ing, i) => (
                      <li
                        class="ing-chip inline-flex items-center h-7 px-3 rounded-full bg-white/10 backdrop-blur-sm border border-white/20 text-xs font-medium text-white opacity-0 -translate-y-2 transition-all duration-400"
                        style={`transition-delay: ${100 + i * 70}ms;`}
                      >
                        {ing}
                      </li>
                    ))}
                  </ul>
                </div>
              </div>
            </div>
          </article>
        ))}
      </div>

      <div class="mt-16 flex flex-col sm:flex-row items-center justify-center gap-3">
        <a href="prototipo-1" class="inline-flex items-center gap-2 h-12 px-6 rounded-full bg-white text-[#0d0907] font-semibold hover:bg-white/90 transition-colors">
          ← Vedi Prototipo 1
        </a>
        <a href={import.meta.env.BASE_URL} class="inline-flex items-center gap-2 h-12 px-6 rounded-full bg-white/10 border border-white/20 text-white font-semibold hover:bg-white/15 transition-colors">
          Torna al sito
        </a>
      </div>
    </div>
  </section>

  <style>
    /* Chips animate in only when drawer is open */
    .pizza-card:hover .ing-chip,
    .pizza-card:focus-within .ing-chip,
    .pizza-card.is-active .ing-chip {
      opacity: 1;
      transform: translateY(0);
    }
    /* Card lift */
    .pizza-card {
      transition: transform 0.6s cubic-bezier(0.22, 1, 0.36, 1);
    }
    .pizza-card:hover, .pizza-card:focus-within, .pizza-card.is-active {
      transform: translateY(-6px);
    }
  </style>

  <script>
    // Mobile fallback — toggle .is-active on tap
    document.querySelectorAll<HTMLElement>('[data-card]').forEach((card) => {
      card.addEventListener('click', (e) => {
        if ((e.target as HTMLElement).closest('a')) return;
        if (!window.matchMedia('(hover: hover)').matches) {
          card.classList.toggle('is-active');
        }
      });
    });
  </script>
</BaseLayout>
