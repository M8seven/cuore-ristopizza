---
import BaseLayout from '../layouts/BaseLayout.astro';
import Events from '../components/Events.astro';
---

<BaseLayout
  title="Eventi"
  description="Gli appuntamenti settimanali di Cuore Ristopizza a Cogliate: Mercoledì Hamburger Day, Giovedì Frittura di mare e calamari su prenotazione."
>
  <section class="pt-12 md:pt-20 pb-6 md:pb-10">
    <div class="max-w-6xl mx-auto px-5 md:px-8">
      <p class="text-sm font-semibold tracking-widest uppercase text-[var(--color-accent)]">Eventi</p>
      <h1 class="mt-3 font-[family-name:var(--font-display)] font-bold text-4xl md:text-6xl">
        Appuntamenti settimanali
      </h1>
      <p class="mt-5 max-w-3xl text-lg text-[var(--color-ink-soft)] leading-relaxed">
        Ogni settimana portiamo in tavola qualcosa di diverso. Prenota il tavolo per essere sicuro
        del tuo posto.
      </p>
    </div>
  </section>
  <Events />
</BaseLayout>
