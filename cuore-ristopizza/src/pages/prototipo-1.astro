---
import BaseLayout from '../layouts/BaseLayout.astro';

// Hotspots: posizione (%) sulla foto della pizza dove vive ogni ingrediente.
// I valori andrebbero affinati visualmente sulla foto reale del cliente quando arriva.
const hotspots = [
  { id: 'pomodoro',   label: 'Pomodoro San Marzano', x: 38, y: 35, dur: 2.4 },
  { id: 'mozza',      label: 'Fiordilatte',          x: 62, y: 28, dur: 2.8 },
  { id: 'basilico',   label: 'Basilico fresco',      x: 50, y: 58, dur: 2.6 },
  { id: 'olio',       label: 'Olio EVO',             x: 30, y: 68, dur: 3.0 },
  { id: 'crosta',     label: 'Crosta lievitata 24h', x: 14, y: 14, dur: 3.2 },
  { id: 'forno',      label: 'Forno a legna 450°',   x: 84, y: 76, dur: 2.2 },
];

const photo = `${import.meta.env.BASE_URL}photos/pizza-hero.jpg`;
---

<BaseLayout title="Prototipo 1 — Anatomia della pizza" noindex={true}>
  <section class="relative min-h-[100vh] flex items-center justify-center overflow-hidden bg-[#0d0907]">
    <!-- Ambient warm radial glow -->
    <div
      class="absolute inset-0 opacity-40 pointer-events-none"
      style="background: radial-gradient(ellipse at 50% 40%, rgba(198,40,40,0.35), transparent 60%);"
      aria-hidden="true"
    ></div>

    <div class="relative max-w-6xl w-full mx-auto px-5 md:px-8 py-20 md:py-28 text-white">
      <header class="reveal text-center max-w-2xl mx-auto mb-12">
        <p class="text-xs sm:text-sm font-semibold tracking-[0.3em] uppercase text-[#ff8a6a]">Prototipo 1 · v3</p>
        <h1 class="mt-4 font-[family-name:var(--font-display)] font-bold text-4xl md:text-6xl">
          Anatomia<br />
          <span class="italic font-normal text-[#ff8a6a]">di una pizza.</span>
        </h1>
        <p class="mt-5 text-white/70 text-lg leading-relaxed">
          Passa il mouse sopra la pizza. Ogni cerchio rivela un ingrediente.
          <span class="block text-sm mt-2 italic opacity-75">Foto stock placeholder — sarà sostituita con foto del ristorante.</span>
        </p>
      </header>

      <!-- Stage with perspective + Ken Burns base -->
      <div class="reveal relative mx-auto max-w-[720px] w-full" style="perspective: 1600px;" data-stage>
        <div
          class="pizza-frame relative aspect-square mx-auto rounded-full overflow-hidden shadow-2xl shadow-black/70"
          style="transform-style: preserve-3d;"
          data-tilt
        >
          <!-- The real photo — Ken Burns slow zoom -->
          <img
            src={photo}
            alt="Pizza margherita vista dall'alto"
            class="ken-burns absolute inset-0 w-full h-full object-cover"
            fetchpriority="high"
            decoding="async"
          />

          <!-- Vignette overlay for depth -->
          <div
            class="absolute inset-0 pointer-events-none"
            style="background: radial-gradient(ellipse at center, transparent 45%, rgba(0,0,0,0.4) 90%);"
            aria-hidden="true"
          ></div>

          <!-- Interactive hotspots -->
          {hotspots.map((h) => (
            <button
              type="button"
              class="hotspot absolute"
              style={`left: ${h.x}%; top: ${h.y}%; --dur: ${h.dur}s;`}
              data-hotspot={h.id}
              aria-label={h.label}
            >
              <span class="hot-ring" aria-hidden="true"></span>
              <span class="hot-ring hot-ring-2" aria-hidden="true"></span>
              <span class="hot-dot" aria-hidden="true"></span>
              <span class="hot-label">{h.label}</span>
            </button>
          ))}
        </div>

        <!-- Caption strip below pizza -->
        <div class="mt-8 flex flex-wrap items-center justify-center gap-3 text-sm text-white/60">
          {hotspots.map((h) => (
            <span class="legend-chip inline-flex items-center gap-2 px-3 h-8 rounded-full border border-white/10 hover:border-[#ff8a6a]/60 hover:bg-white/5 transition-colors cursor-pointer" data-legend={h.id}>
              <span class="w-1.5 h-1.5 rounded-full bg-[#ff8a6a]"></span>
              {h.label}
            </span>
          ))}
        </div>
      </div>

      <div class="reveal mt-14 flex flex-col sm:flex-row items-center justify-center gap-3">
        <a href="prototipo-2" class="inline-flex items-center gap-2 h-12 px-6 rounded-full bg-white text-[#0d0907] font-semibold hover:bg-white/90 transition-colors">
          Vedi Prototipo 2 →
        </a>
        <a href={import.meta.env.BASE_URL} class="inline-flex items-center gap-2 h-12 px-6 rounded-full bg-white/10 border border-white/20 text-white font-semibold hover:bg-white/15 transition-colors">
          ← Torna al sito
        </a>
      </div>
    </div>
  </section>

  <style>
    /* Slow cinematic zoom on the photo */
    @keyframes ken-burns {
      0%   { transform: scale(1) translate(0, 0); }
      50%  { transform: scale(1.08) translate(-1%, 1%); }
      100% { transform: scale(1) translate(0, 0); }
    }
    .ken-burns {
      animation: ken-burns 24s ease-in-out infinite;
      will-change: transform;
    }

    /* Hotspots */
    .hotspot {
      position: absolute;
      width: 22px;
      height: 22px;
      margin: -11px 0 0 -11px;
      cursor: pointer;
      background: transparent;
      border: 0;
      padding: 0;
      z-index: 10;
    }
    .hot-dot {
      position: absolute;
      inset: 0;
      border-radius: 50%;
      background: #ff8a6a;
      box-shadow: 0 0 0 3px rgba(0, 0, 0, 0.55), 0 0 18px rgba(255, 138, 106, 0.55);
      transition: transform 0.3s cubic-bezier(0.22, 1, 0.36, 1);
    }
    .hot-ring {
      position: absolute;
      inset: 0;
      border-radius: 50%;
      border: 1.5px solid #ff8a6a;
      animation: pulse-ring var(--dur, 2.6s) cubic-bezier(0.5, 0, 0.5, 1) infinite;
      opacity: 0;
    }
    .hot-ring-2 {
      animation-delay: calc(var(--dur, 2.6s) / -2);
    }
    @keyframes pulse-ring {
      0%   { transform: scale(0.8); opacity: 0; }
      30%  { opacity: 1; }
      100% { transform: scale(3.4); opacity: 0; }
    }

    .hot-label {
      position: absolute;
      left: 50%;
      bottom: calc(100% + 14px);
      transform: translate(-50%, 6px);
      white-space: nowrap;
      padding: 6px 12px;
      font-family: var(--font-display);
      font-size: 14px;
      font-weight: 600;
      color: white;
      background: rgba(13, 9, 7, 0.95);
      border: 1px solid rgba(255, 138, 106, 0.4);
      border-radius: 999px;
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.25s, transform 0.3s cubic-bezier(0.22, 1, 0.36, 1);
      box-shadow: 0 6px 20px rgba(0, 0, 0, 0.5);
    }
    .hot-label::after {
      content: '';
      position: absolute;
      top: 100%;
      left: 50%;
      transform: translateX(-50%);
      border: 5px solid transparent;
      border-top-color: rgba(13, 9, 7, 0.95);
    }

    .hotspot:hover .hot-dot,
    .hotspot:focus-visible .hot-dot,
    .hotspot.is-active .hot-dot {
      transform: scale(1.5);
    }
    .hotspot:hover .hot-label,
    .hotspot:focus-visible .hot-label,
    .hotspot.is-active .hot-label {
      opacity: 1;
      transform: translate(-50%, 0);
    }
    .hotspot:hover ~ .hotspot .hot-ring,
    .hotspot:focus-visible ~ .hotspot .hot-ring {
      animation-play-state: paused;
      opacity: 0.3;
    }

    /* Legend chip → highlight related hotspot */
    .legend-chip:hover { color: white; }

    @media (prefers-reduced-motion: reduce) {
      .ken-burns { animation: none; }
      .hot-ring { animation: none; opacity: 0.4; transform: scale(1.5); }
    }
  </style>

  <script>
    // 3D mouse tilt on the pizza frame
    const stage = document.querySelector<HTMLElement>('[data-stage]');
    const tilt = document.querySelector<HTMLElement>('[data-tilt]');
    if (stage && tilt && window.matchMedia('(hover: hover)').matches) {
      let raf = 0;
      let tx = 0, ty = 0, cx = 0, cy = 0;
      stage.addEventListener('mousemove', (e) => {
        const rect = stage.getBoundingClientRect();
        const px = (e.clientX - rect.left) / rect.width - 0.5;
        const py = (e.clientY - rect.top) / rect.height - 0.5;
        tx = py * -8;
        ty = px * 12;
        if (!raf) raf = requestAnimationFrame(animate);
      });
      stage.addEventListener('mouseleave', () => {
        tx = 0; ty = 0;
        if (!raf) raf = requestAnimationFrame(animate);
      });
      function animate() {
        cx += (tx - cx) * 0.08;
        cy += (ty - cy) * 0.08;
        tilt!.style.transform = `rotateX(${cx.toFixed(2)}deg) rotateY(${cy.toFixed(2)}deg)`;
        if (Math.abs(cx - tx) > 0.05 || Math.abs(cy - ty) > 0.05) {
          raf = requestAnimationFrame(animate);
        } else {
          raf = 0;
        }
      }
    }

    // Legend chips link to hotspots
    document.querySelectorAll<HTMLElement>('[data-legend]').forEach((chip) => {
      const id = chip.dataset.legend;
      const target = document.querySelector<HTMLElement>(`[data-hotspot="${id}"]`);
      if (!target) return;
      const activate = () => target.classList.add('is-active');
      const deactivate = () => target.classList.remove('is-active');
      chip.addEventListener('mouseenter', activate);
      chip.addEventListener('mouseleave', deactivate);
      chip.addEventListener('focus', activate);
      chip.addEventListener('blur', deactivate);
    });
  </script>
</BaseLayout>
