---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Manifesto from '../components/Manifesto.astro';
import MonthlySpecialFeatured from '../components/MonthlySpecialFeatured.astro';
import FeaturedPizzas from '../components/FeaturedPizzas.astro';
import Events from '../components/Events.astro';
import InteractiveMenu from '../components/InteractiveMenu.astro';
import Marquee from '../components/Marquee.astro';
---

<BaseLayout>
  <Hero />
  <Manifesto />
  <Marquee tone="ink" />
  <MonthlySpecialFeatured />
  <FeaturedPizzas />
  <Events />
  <Marquee
    tone="cream"
    items={['Margherita 5€', 'Diavola 7€', 'Cuore ❤', 'Brigante 8€', 'Zuccaccio del mese', 'Mezzo Metro disponibile', 'Hamburger Day Mer', 'Frittura Gio']}
  />
  <InteractiveMenu />
</BaseLayout>
